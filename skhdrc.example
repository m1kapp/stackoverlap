# StackOverlap - 창 배치 단축키
#
# ⌥⌘ + 키 = 해당 방향으로 배치
# 반복 누르면 순환: 1/2 → 2/3 → 3/4
#
#   Q  W  E
#   A     D
#   Z  X  C

# 모서리
alt + cmd - q : __WINLAYOUT__ q
alt + cmd - e : __WINLAYOUT__ e
alt + cmd - z : __WINLAYOUT__ z
alt + cmd - c : __WINLAYOUT__ c

# 가장자리
alt + cmd - w : __WINLAYOUT__ w
alt + cmd - a : __WINLAYOUT__ a
alt + cmd - d : __WINLAYOUT__ d
alt + cmd - x : __WINLAYOUT__ x

# 전체화면 토글
alt + cmd - s : __WINLAYOUT__ s
